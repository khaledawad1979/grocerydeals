# ─── Kroger API (required for Kroger-family store deals) ─────────────────────
# Register at: https://developer.kroger.com
# Create a new application and choose the "product.compact" scope.
KROGER_CLIENT_ID=your_kroger_client_id_here
KROGER_CLIENT_SECRET=your_kroger_client_secret_here

# ─── Server config ────────────────────────────────────────────────────────────
PORT=3001

# Origin of the React dev server (used for CORS). Change for production.
CLIENT_ORIGIN=http://localhost:3000
